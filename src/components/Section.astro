---
interface Props {
  border: string;
  className?: string;
}
const { border, className } = Astro.props
---

<section class={`relative w-full max-w-screen-lg mx-auto py-12 lg:py-16 xl:py-20 ${border} ${className} border-x-[1px] border-zinc-900`}>
      <main class="max-w-screen-md mx-auto w-full h-full px-5">
        <span class="absolute top-0 left-0 w-3.5 h-px bg-zinc-600"></span>
        <span class="absolute top-[-14px] left-0 h-7 w-px bg-zinc-600"></span>
        <span class="absolute top-0 right-0 w-3.5 h-px bg-zinc-600"></span>
        <span class="absolute top-[-14px] right-0 h-7 w-px bg-zinc-600"></span>
        <slot />
      </main>
    </section>
