---
import Section from "./Section.astro";
import LinkExt from "./ui/LinkExt.astro";
import InfiniteScroll from "./ui/InfiniteScroll.astro";
import {Image} from "astro:assets"
import minion from "../assets/minion.gif"
import ModeChanger from "./ModeChanger.astro";
import { DndContext } from '@dnd-kit/core';
import {Draggable} from "./ui/draggable/Draggable.jsx"
import { useState } from "react";

---
<DndContext>
<Section border="border-b-[1px]">
  <div class="flex items-center flex-col max-sm:items-start gap-9 will-change-auto">
    <div class="flex flex-col items-start ">
      <div class="w-full md:w-2/4">
        <h1 class="text-3xl ClashDisplay-regular pb-3">Frontend Web Developer</h1>
        <span class="text-darks-lightgray leading-relaxed pb-3">
          I'm a frontend web developer and digital marketing enthusiast especially with a primary focus on SEM, SEO and Web Development using JavaScript framework.
        </span>
      </div>
    </div>
    <!-- Balloon 'is-dark'  -->
    <div class="w-full flex justify-center">
      <Image
      draggable="true"
      loading="eager"
        class="flex rounded-md aspect-square object-cover "
        width={300}
        height={274}
        src={minion}
        alt="gue"
        />
    </div>
  </div>
  <InfiniteScroll />
  </Section>
</DndContext>