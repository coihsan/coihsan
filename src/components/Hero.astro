---
import Section from "./Section.astro";
import LinkExt from "./ui/LinkExt.astro";
import SubHero from "./SubHero.astro"
import InfiniteScroll from "./ui/InfiniteScroll.astro";
---

<Section border="border-t-[1px] border-b-[1px]">
  <div class="flex max-md:flex-col items-center gap-9">
    <div class="flex items-center gap-9">
      <img
      class="rounded-md max-sm:w-20 max-sm:h-20"
      width={300}
      height={200}
      src="/public/gue.webp"
      alt="gue"
    />
    <div class="flex flex-col gap-4">
      <h3 class="font-bold text-4xl">˗ˏˋIhsanˎˊ</h3>
      <span>
        I'm Frontend Developer <LinkExt href="/">@Kaisar.id</LinkExt>
      </span>
      <SubHero className="hidden md:hidden lg:flex" />
    </div>
  </div>
    <SubHero className="flex lg:hidden" />
  </div>
  <InfiniteScroll />
  </Section>