---
import Pulse from "./ui/Pulse.astro"
import { navlink } from "../const"
---
    <header class="w-full max-w-screen-lg mx-auto border-x-[1px] border-b-[1px] border-zinc-900 py-4 max-sm:fixed top-0 left-0 z-50 bg-zinc-950/20 backdrop-blur-lg">
        <div class="flex items-center justify-between max-w-screen-md mx-auto w-full px-5">
            <Pulse />
            <div class="flex items-center">
                <nav id="navbar" class="flex lg:flex items-center gap-2">
                    {navlink.map((link)=>(
                        <a class="hover:text-lime-400 transition-all duration-300 ease-linear px-4 py-2 bg-zinc-900 rounded-md border-zinc-900" href={link.href}>{link.text}</a>
                    ))}
                </nav>
            </div>
        </div>
    </header>