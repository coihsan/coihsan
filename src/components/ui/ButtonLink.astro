---
interface Props{
    source?: any;
    preview?: any;
    clasName?: string;
}
const {source, preview, clasName} = Astro.props
import { Image } from 'astro:assets';
---
<div class={`${clasName} flex items-center`}>
    <a class="buttonLink" href={preview} target="_blank" rel="noopener noreferrer" aria-label="View project preview">
        <span>Preview</span>
        <Image width={14} height={14} src="/boxlink.svg" alt="icon link">
    </a>
    <a class="buttonLink ml-3" href={source} target="_blank" rel="noopener noreferrer" aria-label="View project source code">
        <span>Source</span>
        <Image width={14} height={14} src="/boxlink.svg" alt="icon link">
    </a>
</div>