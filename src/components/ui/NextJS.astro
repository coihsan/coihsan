---
import DotLight from "./DotLight.astro"
---
<div class="drop-shadow-xl max-w-[412px] w-full h-60 bg-zinc-950 border border-zinc-900 rounded-lg p-5 group mx-auto">
    <DotLight />
    <a
      href="https://nextjs.org/"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-end justify-between mt-6"
    >
      <div class="grid">
        <h2 class="text-[1.5rem] font-bold">Next.js 14</h2>
        <p class="text-sm text-zinc-400 w-60">
          The power of full-stack to the frontend. Read the release notes.
        </p>
      </div>
      <div class="flex items-center justify-center p-2 rounded-full bg-zinc-800 group-hover:bg-zinc-600 transition-all ease-linear duration-300">
        <img width={24} height={24} src="/arrow-right.svg" alt="arrow right">
      </div>
    </a>
</div>