---
import {Image} from 'astro:assets'
import houston from '@assets/houston.webp'
import {Icon} from "astro-icon/components"
---
<a href="https://astro.build/" target="_blank" class={`overflow-hidden group relative w-full h-60 md:h-60 lg:h-auto py-5 px-9 border border-zinc-900 rounded-lg mx-auto`}>
    <div class="absolute rounded-lg inset-0 -z-10 h-full w-full items-center px-5 py-24 [background:radial-gradient(125%_125%_at_50%_10%,#000_40%,#63e_100%)]"></div>
    <div class="flex flex-col items-center justify-center">
        <Icon name="astrologo" width={120} height={50} />
        <span class="font-semibold text-2xl text-center">Start building<br>with Astro today</span>
        <Image class="" src={houston} width={120} height="auto" alt="houston logo" />
    </div>
</a>