---
import { useState } from "@astrojs/preact"
const isCopied = false
---
<button type="button" onclick="handleCopy()" id="buttonCopy" class="bg-zinc-950 border border-zinc-900 hover:border-zinc-800 flex items-center justify-center gap-3 px-4 py-3 rounded-md hover:bg-zinc-900 transitionAll">
    <img src="/copy-alt.svg" width={24} height={24} alt="copy">
    <span id="textCopy">{isCopied ? "Copied!" : "E-Mail"}</span>
</button>

