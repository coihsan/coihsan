---
import { Icon } from 'astro-icon/components';
interface Props{
    title: string;
    icon: string;
    className?: string;
}
const {title, icon, className } = Astro.props
---
<div class={`${className} flex items-center gap-4 mb-6`}>
    <div class="flex items-center justify-center p-2 rounded-md bg-zinc-950 border border-zinc-900">
        <Icon width={24} height={24} name={icon} />
    </div>
    <h2 class="text-2xl font-bold">{title}</h2>
</div>