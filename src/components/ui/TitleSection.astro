---
interface Props{
    title: string;
    icon: string;
    className?: string;
}
const {title, icon, className } = Astro.props
---
<div class={`${className} flex items-center gap-4 mt-12 mb-6`}>
    <div class="flex items-center justify-center p-2 rounded-md bg-zinc-950 border border-zinc-900">
        <img width={24} height={24} src={icon} alt="icon">
    </div>
    <h2 class="text-2xl font-semibold">{title}</h2>
</div>