---
import { Icon } from 'astro-icon/components';
import {Image} from "astro:assets"
const {link, src, alt, title, description, usecase, logo,logoAlt } = Astro.props;
---
<a href={link} class="componentStyle rounded-lg cursor-pointer flex items-center max-sm:flex-col gap-6 w-full h-auto lg:min-h-32 p-5 group">
    <div class="w-full lg:max-w-[350px]">
        <Image 
        width={300}
        height={300}
        class="rounded-lg w-auto"  
        loading="eager"
        src={src} 
        alt={alt} />
    </div>
    <div class="relative h-full w-full">
        <div class="flex items-center gap-3 mb-3 lg:mb-6">
            <img class="rounded-lg w-auto bg-zinc-950 border border-zinc-900 p-1 h-10 w-10" width={22} height={22} src={logo} alt={logoAlt} />
            <h2 class="font-bold text-[1.2rem] titleOnCard">{title}</h2>
        </div>
        <p class="text-zinc-400 text-sm line-clamp-3 textxs">{description}</p>
        <div class="relative lg:absolute pt-6 lg:pt-0 left-0 bottom-0 flex items-center justify-between w-full">
            <span>{usecase}</span>
            <span class="buttonLink">
                <span class="textxs">Visit</span>
                <Icon width={14} height={14} name="boxlink"/>
            </span>
        </div>
    </div>
</a>