---
import { techstack } from "../const";
import { Icon } from 'astro-icon/components';
interface stack{
    index: typeof techstack ; otherstack: any;
    last?: boolean;
    x: number;
    y: number;
}
const {index , x= 0, y, last} = Astro.props as stack
---

<div class="grid grid-cols-3 max-sm:grid-cols-2 gap-4 w-full">
    {index.slice(x, y).map((list)=>(
        <a href={list.href} class={`flex items-center justify-between componentStyle rounded-md px-5 py-3 group group/item relative last:[iconStack]-hidden
            ${last ? "" : "last-of-type:hover-none last-of-type:text-zinc-600 last-of-type:bg-transparent last-of-type:border-0 last-of-type:cursor-not-allowed last-of-type:aria-disabled"}`}>
            <span class="flex items-center gap-3 last:bg-transparent">
                <span class="bg-zinc-900 group-hover:bg-zinc-800 group-hover:border-zinc-700 rounded-md border border-zinc-800 p-2 w-10 h-10 flex items-center justify-between transitionAll">
                    <Icon name={list.icon} width={24} height={24} />
                </span>
                <span class="text-sm textxs">{list.title}</span>
            </span>
            <Icon height={24} width={24} class="hidden lg:flex fill-zinc-700 rotate-[-45deg] transitionAll" name="arrow-right" />
        </a>
    ))}
</div>
