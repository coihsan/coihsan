---
interface Props{
    title: string;
    description: string;
    bgColor: string;
}
const {title, description, bgColor} = Astro.props
---

<section class={`${bgColor} relative w-full max-w-screen-lg mx-auto pt-12 lg:pt-14 xl:pt-6 border-x-[1px] border-b-[1px] border-zinc-900`}>
    <div class="max-w-screen-md mx-auto w-11/12 p-9 flex justify-center flex-col bg-zinc-950 rounded-t-lg">
        <div class="relative h-full w-full bg-white"><div class="absolute bottom-0 left-0 right-0 top-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,#000_70%,transparent_110%)]"></div></div>
        <h1 class="text-4xl font-bold titleHeading">{title}</h1>
        <span class="text-zinc-400 mt-3 text-sm textxs">{description}</span>
    </div>
</section>