---
import BaseHead from "../layouts/BaseHead.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Contact from "../components/Contact.astro";
import Overlay from "@components/ui/Overlay.astro"
import Navigation from "@components/preact/Navigation";
import { SITE_TITLE, SITE_DESCRIPTION } from "../const"
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} thisSite={"Frontend Developer"}/>
	</head>
	<body>
		<Navigation />
		<main>
			<Overlay />
			<slot />
		</main>
		<Contact />
		<Footer />
	</body>
</html>

