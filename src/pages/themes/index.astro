---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from '../../layouts/Layout.astro'
const posts = (await getCollection("themes")).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
);
import Section from "@components/Section.astro";
import HeadingPages from "@components/HeadingPages.astro"
---

<Layout title='Theme Collections'>
	<HeadingPages title="Theme Collections" description="It's my collections themes with variant frameworks javascript"/>
	<Section border="">
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-4">
			{
				posts.map((post) => (
					<div class="border border-zinc-600/30 rounded-lg bg-onyx-950 hover:scale-[1.03] transition-all ease-linear duration-150">
						<a
							class="relative"
							href={`/themes/${post.slug}/`}
						>
							<img
								class="rounded-t-lg object-cover h-[200px]"
								width={720}
								height={360}
								src={post.data.heroImage?.src}
								alt={post.data.heroImage?.alt}
							/>
							<div class="p-5">
								<div class="flex items-center justify-between border-b-[1px] border-zinc-900 pb-3">
									<span class="text-[14px] text-zinc-400 leading-none border border-zinc-900 px-2 py-1 rounded-md">
										{post.data.techstack}
									</span>
									<span class="text-[14px] text-zinc-400 leading-none">
										{post.data.category}
									</span>
								</div>
								<div class="pt-3">
									<h4 class="text-[1.2rem] leading-6">
										{post.data.title}
									</h4>
								</div>
							</div>
						</a>
					</div>
				))
			}
		</div>
	</Section>
</Layout>