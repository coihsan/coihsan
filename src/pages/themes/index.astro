---
import { getCollection } from "astro:content";
const posts = (await getCollection("Themes")).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
	);
import Layout from '../../layouts/Layout.astro'
import Section from "@components/Section.astro";
import HeadingPages from "@components/HeadingPages.astro"
import CardThemes from "@components/CardThemes.astro";
---

<Layout title='Theme Collections'>
	<HeadingPages title="Theme Collections" description="It's my collections themes with variant frameworks javascript"/>
	<Section border="">
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-4">
			{
				posts.map((post) => (
				<CardThemes href={post.slug} src={post.data.heroImage} alt={post.data.heroImageAlt} title={post.data.title} techstack={post.data.techstack} category={post.data.category} source={post.data.category} preview={post.data.category}/>
				))
			}
		</div>
	</Section>
</Layout>