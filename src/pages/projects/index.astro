---
import ProjectsLayout from '../../layouts/ProjectsLayout.astro'
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Section from '@components/Section.astro';
const posts = (await getCollection("projects")).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
);
import HeadingPages from "@components/HeadingPages.astro"
---

<ProjectsLayout title='Projects Collections'>
	<HeadingPages title="Project Experiences" description="It's my collections themes with variant frameworks javascript"/>
	<Section border=''>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-4">
			{
				posts.map((post) => (
					<div class="border border-zinc-600/30 rounded-lg bg-onyx-950">
						<a
							class="relative max-sm:flex"
							href={`/projects/${post.slug}/`}
						>
							<img
								class="rounded-lg max-sm:hidden"
								width={720}
								height={360}
								src={post.data.heroImage?.src}
								alt={post.data.heroImage?.alt}
							/>
							<div class="p-5">
								<div class="pb-2 flex items-center justify-between divide-zinc-200">
									<div class="flex items-center gap-1 ">
										<span class="text-[14px] text-zinc-400 leading-none">
											{post.data.category}
										</span>
									</div>
								</div>
								<div class="pt-5">
									<h4 class="text-[1.2rem] leading-6">
										{post.data.title}
									</h4>
								</div>
							</div>
						</a>
					</div>
				))
			}
		</div>
	</Section>
</ProjectsLayout>