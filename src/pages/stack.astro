---
import Layout from '../layouts/Layout.astro'
import Section from '../components/Section.astro'
import WrapperList from '@components/WrapperList.astro'
import { otherstack, techstack } from 'src/const'
---

<Layout title="My Tech Stack">
	<Section border=''>
        <h1 class="mb-6">My Stack</h1>
        <WrapperList index={techstack} />
        <h3 class="my-6">Other Stack</h3>
        <WrapperList index={otherstack} />
    </Section>
</Layout>